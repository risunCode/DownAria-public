# ═══════════════════════════════════════════════════════════════
# FRONTEND Environment Configuration
# ═══════════════════════════════════════════════════════════════
# This is the FRONTEND UI that users interact with
# Port: 3001 (default)
# ═══════════════════════════════════════════════════════════════

# ┌─────────────────────────────────────────────────────────────┐
# │ APP URLs (Required)                                         │
# └─────────────────────────────────────────────────────────────┘

LOG_LEVEL=info  # ← error | info | debug
NODE_ENV=development  # ← Development | Production
NEXT_PUBLIC_APP_URL=http://localhost:3001 # ← Frontend URL

# API Server
NEXT_PUBLIC_API_URL=http://localhost:8081 # ← Backend API URL
WEB_INTERNAL_SHARED_SECRET=change-this-in-production

# Storage
NEXT_PUBLIC_STORAGE_KEY=

# About feedback webhook (server-side)
FEEDBACK_DISCORD_WEBHOOK_URL=
